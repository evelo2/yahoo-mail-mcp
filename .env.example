YAHOO_EMAIL=your-email@yahoo.com
YAHOO_APP_PASSWORD=your-16-char-app-password
RULES_CONFIG_PATH=./config/sender-rules.json
IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
IMAP_OP_DELAY_MS=200
LOG_LEVEL=info
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3001
# MCP_API_KEY=your-secret-api-key       # Required for authenticated HTTP transport
# CORS_ALLOWED_ORIGINS=https://example.com  # Comma-separated allowed origins
# RATE_LIMIT_RPM=100                     # Requests per minute per IP (default: 100)
# AUDIT_RETENTION_DAYS=10                # Days to keep audit log entries (default: 10)
