{
  "name": "yahoo-mail-mcp",
  "version": "1.0.0",
  "description": "MCP server proxying Yahoo Mail IMAP access for AI-driven email triage",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "tunnel": "npx tsx scripts/start-tunnel.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.0.171",
    "pino": "^9.6.0",
    "safe-regex2": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
